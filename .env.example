# Port configurations
PORT=5000

# MongoDB Connection String (Atlas URI or local container URI)
# Placeholder value is used here as secrets should not be checked into git
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# WebRTC STUN Server for client traversal
NEXT_PUBLIC_STUN_SERVER=stun:stun.l.google.com:19302
